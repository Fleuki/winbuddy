# ── Вариант A: через aitunnel.ru (оплата в рублях, из России) ──
# Ключ из панели aitunnel (начинается с sk-aitunnel-)
ANTHROPIC_API_KEY=sk-aitunnel-...
# Адрес прокси aitunnel:
ANTHROPIC_BASE_URL=https://api.aitunnel.ru
# Имя модели в формате aitunnel (не claude-sonnet-5!):
WINBUDDY_MODEL=claude-sonnet-4.5

# ── Вариант B: официальный Anthropic (ключ с platform.claude.com) ──
# Тогда закомментируй строки выше и раскомментируй эти:
# ANTHROPIC_API_KEY=sk-ant-...
# (ANTHROPIC_BASE_URL оставить пустым/убрать)
# WINBUDDY_MODEL=claude-sonnet-5

@echo off
rem ============================================================
rem  winbuddy — запуск С видимым терминалом (для отладки)
rem  Если основной winbuddy.bat не работает — запусти этот и
rem  посмотри, какая ошибка появится в окне.
rem ============================================================

set "PROJECT=%~dp0"

echo Активирую venv...
call "%PROJECT%.venv\Scripts\activate.bat"

echo Запускаю winbuddy (окно откроется через пару секунд)...
cd /d "%PROJECT%electron"
npm start

echo.
echo Приложение закрыто. Нажми любую клавишу, чтобы закрыть окно.
pause >nul
